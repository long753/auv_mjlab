+                print(f"  线速度: {linvel_w[0].cpu().numpy()}")
+                print(f"  角速度: {angvel_w[0].cpu().numpy()}")
+                print(f"  总力 (刚体系): {total_force_np}")
+                print(f"  总扭矩 (刚体系): {total_torque_np}")
+                print(f"  位置 z: {data.xpos[root_body_id][2]:.3f}")
+                print()
+            
+            # 仿真步进
             mujoco.mj_step(model, data)
             v.sync()
