+                print(f"  总扭矩 (刚体系): {total_torque_np}")
+                print(f"  位置 z: {data.xpos[root_body_id][2]:.3f}")
+                print()
+            
+            # 仿真步进
             mujoco.mj_step(model, data)
             v.sync()
