-    vel_command_b = command[:, :]   # [num_envs, 3]   
-    vel_norm = torch.norm(vel_command_b, dim=1, keepdim=True)
-    
-    # 处理零速度情况
-    vel_dir_b = torch.where(
-        vel_norm > 1e-6,
-        vel_command_b / vel_norm,
