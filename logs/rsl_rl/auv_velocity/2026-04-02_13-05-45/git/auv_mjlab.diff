-            thruster_joint_names=[                              # 推进器空间
-                "thruster_up_z",
-                "thruster_up_y",
-                "thruster_down_z",
-                "thruster_down_y",
-                "thruster_left_z",
-                "thruster_left_x",
-                "thruster_right_z",
-                "thruster_right_x",
